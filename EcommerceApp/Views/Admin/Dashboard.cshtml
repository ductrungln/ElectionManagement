@{
    ViewData["Title"] = "Bảng điều khiển Admin";
}

<!-- Navigation Menu -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-5">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">🛒 EcommerceApp</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="/">🏠 Trang chủ</a></li>
                <li class="nav-item"><a class="nav-link" href="/shop">🛍️ Cửa hàng</a></li>
                <li class="nav-item"><a class="nav-link" href="/cart">🛒 Giỏ hàng</a></li>
                <li class="nav-item"><a class="nav-link" href="/account/login">👤 Tài khoản</a></li>
                <li class="nav-item"><a class="nav-link active" href="/admin/dashboard">⚙️ Admin</a></li>
            </ul>
        </div>
    </div>
</nav>

<div class="container-fluid mt-5">
    <h1>📊 Bảng điều khiển Admin</h1>
    
    <div class="row mt-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">📦 Sản phẩm</h5>
                    <h2>150</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">👥 Khách hàng</h5>
                    <h2>500</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">📋 Đơn hàng</h5>
                    <h2>1,200</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <h5 class="card-title">💰 Doanh thu</h5>
                    <h2>5M VND</h2>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>📊 Quản lý</h5>
                </div>
                <div class="card-body">
                    <a href="/admin/products" class="btn btn-primary btn-sm mb-2 d-block">Quản lý sản phẩm</a>
                    <a href="/admin/categories" class="btn btn-primary btn-sm mb-2 d-block">Quản lý danh mục</a>
                    <a href="/admin/orders" class="btn btn-primary btn-sm mb-2 d-block">Quản lý đơn hàng</a>
                    <a href="/admin/customers" class="btn btn-primary btn-sm mb-2 d-block">Quản lý khách hàng</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>🎁 Khuyến mãi</h5>
                </div>
                <div class="card-body">
                    <a href="/admin/discounts" class="btn btn-success btn-sm mb-2 d-block">Quản lý mã giảm giá</a>
                    <a href="/admin/promotions" class="btn btn-success btn-sm mb-2 d-block">Flash sale</a>
                    <a href="/admin/banners" class="btn btn-success btn-sm mb-2 d-block">Quản lý banner</a>
                    <a href="#" class="btn btn-success btn-sm mb-2 d-block">Email marketing</a>
                </div>
            </div>
        </div>
    </div>
</div>
