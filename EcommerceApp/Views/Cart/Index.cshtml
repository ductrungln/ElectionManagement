@{
    ViewData["Title"] = "Giỏ hàng";
}

<!-- Navigation Menu -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-5">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">🛒 EcommerceApp</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link" href="/">🏠 Trang chủ</a></li>
                <li class="nav-item"><a class="nav-link" href="/shop">🛍️ Cửa hàng</a></li>
                <li class="nav-item"><a class="nav-link active" href="/cart">🛒 Giỏ hàng</a></li>
                <li class="nav-item"><a class="nav-link" href="/account/login">👤 Tài khoản</a></li>
                <li class="nav-item"><a class="nav-link" href="/admin/dashboard">⚙️ Admin</a></li>
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-5">
    <h1>🛒 Giỏ hàng của bạn</h1>
    
    <div class="row mt-4">
        <div class="col-md-8">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Giá</th>
                        <th>Số lượng</th>
                        <th>Tổng</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="/images/placeholder.jpg" alt="Product" style="width: 50px; height: 50px; margin-right: 10px;">
                                <span>Sản phẩm mẫu</span>
                            </div>
                        </td>
                        <td>800,000 VND</td>
                        <td>
                            <input type="number" value="1" min="1" class="form-control" style="width: 80px;">
                        </td>
                        <td>800,000 VND</td>
                        <td>
                            <button class="btn btn-danger btn-sm">❌</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Tóm tắt đơn hàng</h5>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Tạm tính:</span>
                        <span>800,000 VND</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Vận chuyển:</span>
                        <span>25,000 VND</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 border-top pt-3">
                        <strong>Tổng cộng:</strong>
                        <strong class="text-danger">825,000 VND</strong>
                    </div>
                    
                    <div class="mb-3">
                        <label>Mã giảm giá:</label>
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Nhập mã">
                            <button class="btn btn-outline-primary">Áp dụng</button>
                        </div>
                    </div>
                    
                    <div class="d-grid gap-2">
                        <a href="/checkout" class="btn btn-primary btn-lg">Thanh toán</a>
                        <a href="/shop" class="btn btn-outline-secondary">Tiếp tục mua hàng</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
