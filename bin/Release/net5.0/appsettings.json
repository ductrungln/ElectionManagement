{
  "ConnectionStrings": {
    // switched to SQLite file to avoid LocalDB dependency; database file is created next to the exe
    "DefaultConnection": "Data Source=ElectionManagement.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "ThisIsAVeryLongSecretKeyForJwtTokenGenerationAtLeast32Characters!",
    "Issuer": "ElectionManagement",
    "Audience": "ElectionUsers",
    "ExpirationMinutes": 60
  }
}
